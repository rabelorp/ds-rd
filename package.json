{
  "name": "@rabelo-digital/ds-rd",
  "version": "1.1.0",
  "description": "Rabelo Digital Design System",
  "keywords": [
    "design-system",
    "react",
    "components",
    "tokens",
    "rabelo-digital"
  ],
  "homepage": "https://github.com/rabelo-digital/ds-rd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rabelo-digital/ds-rd.git"
  },
  "license": "MIT",
  "author": "Rabelo Digital <contato@rabelodigital.com.br>",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.cjs"
    },
    "./tokens.css": "./tokens.css"
  },
  "files": [
    "dist",
    "tokens.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"*.{json,md,cjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"*.{json,md,cjs}\"",
    "typecheck": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run typecheck",
    "ci:check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "test-storybook": "test-storybook",
    "commit": "cz",
    "release": "standard-version",
    "prepare": "husky install",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:dry-run": "standard-version --dry-run"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ],
    "*.{json,md,cjs}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@size-limit/preset-small-lib": "^11.1.4",
    "@storybook/addon-a11y": "^8.2.9",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-themes": "^8.2.9",
    "@storybook/react": "^8.2.9",
    "@storybook/react-vite": "^8.2.9",
    "@storybook/test-runner": "^0.19.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.0.5",
    "axe-playwright": "^2.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "8.0.1",
    "jsdom": "^24.1.1",
    "lint-staged": "13.0.3",
    "prettier": "^3.8.4",
    "size-limit": "^11.1.4",
    "storybook": "^8.2.9",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vitest": "^2.0.5",
    "standard-version": "^9.5.0",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "react-icons": "^5.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "./dist/index.mjs",
      "limit": "50 KB"
    }
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
